# JobTracker backend environment example.
# Copy to backend/.env for local overrides only.
# Do not put API keys, OAuth tokens, passwords, or client secrets in this file.
# Secrets belong in the first-run setup flow backed by OS keyring by default.
# Use the Fernet backend when OS keyring is unavailable.

# Runtime
JOBTRACKER_ENV=development
JOBTRACKER_API_HOST=127.0.0.1
JOBTRACKER_API_PORT=8000
JOBTRACKER_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
JOBTRACKER_FRONTEND_URL=http://127.0.0.1:5173
JOBTRACKER_LOG_LEVEL=INFO

# Local storage
# Recursive wipe safety requires JOBTRACKER_DATA_DIR to be named .jobtracker or to contain a .jobtracker-data marker file.
# Without that marker, POST /local-data/wipe refuses custom directory names with a typed 400 instead of deleting them.
# Add that marker file yourself before using a custom app-owned data directory name.
JOBTRACKER_DATA_DIR=./.jobtracker
# The code default resolves to jobtracker.sqlite3 in the repository root regardless of the launch directory.
# This relative override assumes backend/ is the current working directory.
# If this local SQLite file lives outside JOBTRACKER_DATA_DIR, wipe-data also deletes its -wal, -shm, and -journal sidecars.
JOBTRACKER_DATABASE_URL=sqlite+aiosqlite:///../jobtracker.sqlite3
# Optional: override the bundled sqlite-vec loadable extension path used by the SQLite engine.
JOBTRACKER_SQLITE_VEC_EXTENSION_PATH=

# Secret storage
# JOBTRACKER_SECRET_STORE_BACKEND allowed values: keyring, fernet.
# keyring is the architectural default; select fernet when keyring is unavailable.
# Fernet fallback writes encrypted payloads under JOBTRACKER_DATA_DIR/secrets/ and uses JOBTRACKER_FERNET_KEY_FILE as the encryption key.
# Default Fernet paths are wiped by POST /local-data/wipe because they live under JOBTRACKER_DATA_DIR.
# Keep the Fernet key and encrypted secret files out of git; see ../docs/secret-storage.md.
# Both keyring and fernet are usable through the configured secret-store factory.
JOBTRACKER_SECRET_STORE_BACKEND=keyring
JOBTRACKER_FERNET_KEY_FILE=./.jobtracker/fernet.key

# Providers
# GET /config/providers exposes these selected choices and visible non-secret provider settings.
# PUT /config/providers can update them for the running backend process, but does not persist secrets or durable setup state yet.
# POST /config/providers/llm/health validates selected non-secret LLM settings and checks configured models through the wired adapter.
# JOBTRACKER_EMAIL_PROVIDER allowed values: gmail.
JOBTRACKER_EMAIL_PROVIDER=gmail
# JOBTRACKER_LLM_PROVIDER allowed values: azure_openai, ollama.
JOBTRACKER_LLM_PROVIDER=ollama
# JOBTRACKER_CLASSIFICATION_MODE allowed values: hybrid, llm, local.
# Setup recommends hybrid for Azure OpenAI and local for Ollama when no explicit mode is submitted.
# Explicit provider-valid modes remain accepted; Azure OpenAI with local is invalid.
JOBTRACKER_CLASSIFICATION_MODE=local

# Gmail ingestion
# See ../docs/google-oauth-setup.md for the user-created Google OAuth client setup.
# Keep this outside the repository because Google OAuth client JSON can contain a client secret.
# GET /auth/gmail reads this file to build a Google authorization URL, but never returns the client secret.
# GET /auth/gmail/callback exchanges the code and stores token material through the configured secret store.
JOBTRACKER_GMAIL_CLIENT_CONFIG_FILE=~/.config/jobtracker/google-oauth-client.json
JOBTRACKER_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly
# When true, the FastAPI lifespan starts an APScheduler interval job immediately on backend startup.
# The concrete Gmail sync runner is still deferred, so the default app job is a safe no-op until that runner is wired.
JOBTRACKER_SYNC_ON_OPEN=true
# Interval, in seconds, for the backend-owned sync-on-open scheduler. Must be at least 1.
JOBTRACKER_SYNC_INTERVAL_SECONDS=900
JOBTRACKER_GMAIL_PAGE_SIZE=500
JOBTRACKER_BACKFILL_BATCH_SIZE=1000
JOBTRACKER_RETAIN_DEBUG_EMAIL_BODIES=false

# Classification and extraction
JOBTRACKER_CLASSIFICATION_BATCH_SIZE=25
JOBTRACKER_CLASSIFICATION_CONCURRENCY=5
JOBTRACKER_PROCESSING_MAX_CANDIDATES_PER_RUN=500
JOBTRACKER_CLASSIFICATION_PROMPT_VERSION=v1
# Heuristic tokenizer estimate used before bulk classification runs.
JOBTRACKER_CLASSIFICATION_ESTIMATE_CHARS_PER_UNIT=4
# Prompt and completion budgets added per candidate for pre-run token estimates.
JOBTRACKER_CLASSIFICATION_ESTIMATE_PROMPT_OVERHEAD_UNITS=300
JOBTRACKER_CLASSIFICATION_ESTIMATE_COMPLETION_UNITS_PER_CANDIDATE=500
# Optional pricing inputs for non-local classification cost estimates.
# Leave at 0 when pricing is unknown; local mode reports zero cost.
JOBTRACKER_CLASSIFICATION_INPUT_COST_PER_1K_UNITS_USD=0
JOBTRACKER_CLASSIFICATION_OUTPUT_COST_PER_1K_UNITS_USD=0
# Heuristic tokenizer estimate used for one insight regeneration prompt.
JOBTRACKER_INSIGHT_ESTIMATE_CHARS_PER_UNIT=4
# Optional pricing inputs for non-local insight regeneration estimates and actual usage.
# Leave at 0 when pricing is unknown; Ollama local mode reports zero cost.
JOBTRACKER_INSIGHT_INPUT_COST_PER_1K_UNITS_USD=0
JOBTRACKER_INSIGHT_OUTPUT_COST_PER_1K_UNITS_USD=0
# Maximum eligible retained job emails reconciled into sqlite-vec per chat request.
JOBTRACKER_CHAT_INDEX_MAX_EMAILS=1000
JOBTRACKER_LLM_TIMEOUT_SECONDS=60
JOBTRACKER_LLM_MAX_RETRIES=2

# Azure OpenAI provider metadata.
# Store Azure credentials outside .env through the configured secret store.
JOBTRACKER_AZURE_OPENAI_ENDPOINT=
JOBTRACKER_AZURE_OPENAI_API_VERSION=2024-06-01
JOBTRACKER_AZURE_OPENAI_CHAT_DEPLOYMENT=
JOBTRACKER_AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Ollama local provider. The runtime adapter and provider registry require this URL to resolve to localhost or a loopback IP.
# Local Ollama HTTP calls use a proxy-disabled transport so proxy environment variables do not reroute prompt content.
JOBTRACKER_OLLAMA_BASE_URL=http://127.0.0.1:11434
JOBTRACKER_OLLAMA_CHAT_MODEL=llama3.1
JOBTRACKER_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Application inference
JOBTRACKER_GHOST_THRESHOLD_DAYS=30
