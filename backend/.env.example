# JobTracker backend environment example.
# Copy to backend/.env for local overrides only.
# Do not put API keys, OAuth tokens, passwords, or client secrets in this file.
# Secrets belong in the first-run setup flow backed by OS keyring or the documented Fernet fallback.

# Runtime
JOBTRACKER_ENV=development
JOBTRACKER_API_HOST=127.0.0.1
JOBTRACKER_API_PORT=8000
JOBTRACKER_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
JOBTRACKER_LOG_LEVEL=INFO

# Local storage
# Recursive wipe safety requires JOBTRACKER_DATA_DIR to be named .jobtracker or to contain a .jobtracker-data marker file.
# Without that marker, POST /local-data/wipe refuses custom directory names with a typed 400 instead of deleting them.
# Add that marker file yourself before using a custom app-owned data directory name.
JOBTRACKER_DATA_DIR=./.jobtracker
# If this local SQLite file lives outside JOBTRACKER_DATA_DIR, wipe-data also deletes its -wal, -shm, and -journal sidecars.
JOBTRACKER_DATABASE_URL=sqlite+aiosqlite:///./.jobtracker/jobtracker.sqlite3
JOBTRACKER_SQLITE_VEC_EXTENSION_PATH=

# Secret storage
# JOBTRACKER_SECRET_STORE_BACKEND allowed values: keyring, fernet.
# Fernet fallback writes encrypted payloads under JOBTRACKER_DATA_DIR/secrets/ and uses JOBTRACKER_FERNET_KEY_FILE as the encryption key.
# Keep the Fernet key and encrypted secret files out of git; see docs/secret-storage.md.
JOBTRACKER_SECRET_STORE_BACKEND=keyring
JOBTRACKER_FERNET_KEY_FILE=./.jobtracker/fernet.key

# Providers
# JOBTRACKER_EMAIL_PROVIDER allowed values: gmail.
JOBTRACKER_EMAIL_PROVIDER=gmail
# JOBTRACKER_LLM_PROVIDER allowed values: azure_openai, ollama.
JOBTRACKER_LLM_PROVIDER=ollama
# JOBTRACKER_CLASSIFICATION_MODE allowed values: hybrid, llm, local.
JOBTRACKER_CLASSIFICATION_MODE=local

# Gmail ingestion
# Keep this outside the repository because Google OAuth client JSON can contain a client secret.
JOBTRACKER_GMAIL_CLIENT_CONFIG_FILE=~/.config/jobtracker/google-oauth-client.json
JOBTRACKER_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly
JOBTRACKER_SYNC_ON_OPEN=true
JOBTRACKER_SYNC_INTERVAL_SECONDS=900
JOBTRACKER_GMAIL_PAGE_SIZE=500
JOBTRACKER_BACKFILL_BATCH_SIZE=1000
JOBTRACKER_RETAIN_DEBUG_EMAIL_BODIES=false

# Classification and extraction
JOBTRACKER_CLASSIFICATION_BATCH_SIZE=25
JOBTRACKER_CLASSIFICATION_PROMPT_VERSION=v1
JOBTRACKER_LLM_TIMEOUT_SECONDS=60
JOBTRACKER_LLM_MAX_RETRIES=2

# Azure OpenAI provider metadata.
# Store Azure credentials outside .env through the configured secret store.
JOBTRACKER_AZURE_OPENAI_ENDPOINT=
JOBTRACKER_AZURE_OPENAI_API_VERSION=2024-06-01
JOBTRACKER_AZURE_OPENAI_CHAT_DEPLOYMENT=
JOBTRACKER_AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Ollama local provider
JOBTRACKER_OLLAMA_BASE_URL=http://127.0.0.1:11434
JOBTRACKER_OLLAMA_CHAT_MODEL=llama3.1
JOBTRACKER_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Application inference
JOBTRACKER_GHOST_THRESHOLD_DAYS=30
