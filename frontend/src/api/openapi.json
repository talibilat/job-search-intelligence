{
  "components": {
    "schemas": {
      "ApiErrorBody": {
        "properties": {
          "code": {
            "$ref": "#/components/schemas/ApiErrorCode"
          },
          "details": {
            "items": {
              "$ref": "#/components/schemas/ApiErrorDetail"
            },
            "title": "Details",
            "type": "array"
          },
          "message": {
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "title": "ApiErrorBody",
        "type": "object"
      },
      "ApiErrorCode": {
        "enum": [
          "bad_request",
          "conflict",
          "forbidden",
          "http_error",
          "internal_error",
          "not_found",
          "unauthorized",
          "validation_error"
        ],
        "title": "ApiErrorCode",
        "type": "string"
      },
      "ApiErrorDetail": {
        "properties": {
          "field": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Field"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "message",
          "type"
        ],
        "title": "ApiErrorDetail",
        "type": "object"
      },
      "ApiErrorResponse": {
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ApiErrorBody"
          }
        },
        "required": [
          "error"
        ],
        "title": "ApiErrorResponse",
        "type": "object"
      },
      "ClassificationMode": {
        "enum": [
          "hybrid",
          "llm",
          "local"
        ],
        "title": "ClassificationMode",
        "type": "string"
      },
      "EmailProviderName": {
        "enum": [
          "gmail"
        ],
        "title": "EmailProviderName",
        "type": "string"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "const": "ok",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "LLMProviderName": {
        "enum": [
          "azure_openai",
          "ollama"
        ],
        "title": "LLMProviderName",
        "type": "string"
      },
      "SetupStatusResponse": {
        "description": "First-run setup readiness and selected non-secret provider settings.",
        "properties": {
          "classification_mode": {
            "$ref": "#/components/schemas/ClassificationMode"
          },
          "email_provider": {
            "$ref": "#/components/schemas/EmailProviderName"
          },
          "gmail_connected": {
            "title": "Gmail Connected",
            "type": "boolean"
          },
          "llm_configured": {
            "title": "Llm Configured",
            "type": "boolean"
          },
          "llm_provider": {
            "$ref": "#/components/schemas/LLMProviderName"
          },
          "setup_complete": {
            "title": "Setup Complete",
            "type": "boolean"
          }
        },
        "required": [
          "setup_complete",
          "gmail_connected",
          "llm_configured",
          "email_provider",
          "llm_provider",
          "classification_mode"
        ],
        "title": "SetupStatusResponse",
        "type": "object"
      },
      "SetupSubmitRequest": {
        "additionalProperties": false,
        "description": "Non-secret first-run setup choices accepted by the Phase 0 API shell.",
        "properties": {
          "azure_openai_api_version": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Azure Openai Api Version"
          },
          "azure_openai_chat_deployment": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Azure Openai Chat Deployment"
          },
          "azure_openai_embedding_deployment": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Azure Openai Embedding Deployment"
          },
          "azure_openai_endpoint": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Azure Openai Endpoint"
          },
          "classification_mode": {
            "$ref": "#/components/schemas/ClassificationMode"
          },
          "email_provider": {
            "$ref": "#/components/schemas/EmailProviderName",
            "default": "gmail"
          },
          "gmail_client_config_file": {
            "anyOf": [
              {
                "format": "path",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Gmail Client Config File"
          },
          "llm_provider": {
            "$ref": "#/components/schemas/LLMProviderName"
          },
          "ollama_base_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ollama Base Url"
          },
          "ollama_chat_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ollama Chat Model"
          },
          "ollama_embedding_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ollama Embedding Model"
          }
        },
        "required": [
          "llm_provider",
          "classification_mode"
        ],
        "title": "SetupSubmitRequest",
        "type": "object"
      },
      "SetupSubmitResponse": {
        "description": "Acknowledgement for a setup submission that has not persisted secrets yet.",
        "properties": {
          "classification_mode": {
            "$ref": "#/components/schemas/ClassificationMode"
          },
          "email_provider": {
            "$ref": "#/components/schemas/EmailProviderName"
          },
          "gmail_connected": {
            "title": "Gmail Connected",
            "type": "boolean"
          },
          "llm_configured": {
            "title": "Llm Configured",
            "type": "boolean"
          },
          "llm_provider": {
            "$ref": "#/components/schemas/LLMProviderName"
          },
          "setup_complete": {
            "title": "Setup Complete",
            "type": "boolean"
          },
          "status": {
            "const": "accepted",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "setup_complete",
          "gmail_connected",
          "llm_configured",
          "email_provider",
          "llm_provider",
          "classification_mode",
          "status"
        ],
        "title": "SetupSubmitResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "WipeDataRequest": {
        "properties": {
          "confirmation": {
            "const": "wipe-local-data",
            "description": "Must exactly equal wipe-local-data to confirm local data deletion.",
            "title": "Confirmation",
            "type": "string"
          }
        },
        "required": [
          "confirmation"
        ],
        "title": "WipeDataRequest",
        "type": "object"
      },
      "WipeDataResponse": {
        "properties": {
          "deleted_paths": {
            "description": "Canonical local filesystem paths deleted by the wipe operation.",
            "items": {
              "type": "string"
            },
            "title": "Deleted Paths",
            "type": "array"
          },
          "missing_paths": {
            "description": "Canonical local filesystem paths that were already absent.",
            "items": {
              "type": "string"
            },
            "title": "Missing Paths",
            "type": "array"
          },
          "status": {
            "const": "wiped",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "WipeDataResponse",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Job Search Intelligence API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health",
        "tags": [
          "health"
        ]
      }
    },
    "/local-data/wipe": {
      "post": {
        "description": "Deletes configured local JobTracker data and derived artifacts after the request body confirms the exact wipe-local-data phrase. The service preflights every filesystem target and returns a typed 400 error instead of deleting anything when a target is unsafe.",
        "operationId": "wipe_data_local_data_wipe_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WipeDataRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WipeDataResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Bad Request"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Wipe local app data",
        "tags": [
          "local-data"
        ]
      }
    },
    "/setup": {
      "post": {
        "description": "Accepts non-secret Phase 0 setup choices and validates selected provider metadata without running provider auth flows or persisting secrets.",
        "operationId": "setup_submit_setup_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetupSubmitRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetupSubmitResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Bad Request"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Submit first-run setup choices",
        "tags": [
          "setup"
        ]
      }
    },
    "/setup/status": {
      "get": {
        "description": "Report the Phase 0 setup shell without validating or exposing secrets.",
        "operationId": "setup_status_setup_status_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetupStatusResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Setup Status",
        "tags": [
          "setup"
        ]
      }
    }
  }
}
