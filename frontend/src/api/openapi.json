{
  "components": {
    "schemas": {
      "ApiErrorBody": {
        "properties": {
          "code": {
            "$ref": "#/components/schemas/ApiErrorCode"
          },
          "details": {
            "items": {
              "$ref": "#/components/schemas/ApiErrorDetail"
            },
            "title": "Details",
            "type": "array"
          },
          "message": {
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "title": "ApiErrorBody",
        "type": "object"
      },
      "ApiErrorCode": {
        "enum": [
          "bad_gateway",
          "bad_request",
          "conflict",
          "email_authorization_required",
          "email_insufficient_scope",
          "email_invalid_provider_response",
          "email_provider_request_failed",
          "email_rate_limited",
          "email_sync_cursor_expired",
          "email_temporarily_unavailable",
          "forbidden",
          "http_error",
          "internal_error",
          "llm_provider_invalid_response",
          "llm_provider_request_failed",
          "llm_provider_timeout",
          "llm_provider_unavailable",
          "not_found",
          "service_unavailable",
          "unauthorized",
          "validation_error"
        ],
        "title": "ApiErrorCode",
        "type": "string"
      },
      "ApiErrorDetail": {
        "properties": {
          "field": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Field"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "message",
          "type"
        ],
        "title": "ApiErrorDetail",
        "type": "object"
      },
      "ApiErrorResponse": {
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ApiErrorBody"
          }
        },
        "required": [
          "error"
        ],
        "title": "ApiErrorResponse",
        "type": "object"
      },
      "ClassificationMode": {
        "enum": [
          "hybrid",
          "llm",
          "local"
        ],
        "title": "ClassificationMode",
        "type": "string"
      },
      "ClassificationPreRunEstimate": {
        "description": "Public pre-run estimate for a bulk classification pass.",
        "properties": {
          "candidate_count": {
            "description": "Retained candidate emails needing classification for the current model and prompt.",
            "minimum": 0.0,
            "title": "Candidate Count",
            "type": "integer"
          },
          "classification_mode": {
            "$ref": "#/components/schemas/ClassificationMode"
          },
          "cost_estimate_available": {
            "description": "True when the endpoint can report a cost estimate, including zero-cost local mode.",
            "title": "Cost Estimate Available",
            "type": "boolean"
          },
          "currency": {
            "default": "USD",
            "description": "Currency for estimated_cost_usd.",
            "title": "Currency",
            "type": "string"
          },
          "estimated_completion_tokens": {
            "description": "Estimated completion/output tokens from the configured per-candidate budget.",
            "minimum": 0.0,
            "title": "Estimated Completion Tokens",
            "type": "integer"
          },
          "estimated_cost_usd": {
            "anyOf": [
              {
                "minimum": 0.0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "Estimated USD cost, or null when non-local provider pricing is not configured.",
            "title": "Estimated Cost Usd"
          },
          "estimated_prompt_tokens": {
            "description": "Estimated prompt/input tokens from retained body text plus configured overhead.",
            "minimum": 0.0,
            "title": "Estimated Prompt Tokens",
            "type": "integer"
          },
          "estimated_total_tokens": {
            "description": "Sum of estimated prompt and completion tokens.",
            "minimum": 0.0,
            "title": "Estimated Total Tokens",
            "type": "integer"
          },
          "llm_provider": {
            "$ref": "#/components/schemas/LLMProviderName"
          },
          "model": {
            "description": "Configured classification model identifier used to decide stale rows.",
            "minLength": 1,
            "title": "Model",
            "type": "string"
          },
          "prompt_version": {
            "description": "Configured classification prompt version used to decide stale rows.",
            "minLength": 1,
            "title": "Prompt Version",
            "type": "string"
          },
          "token_estimate_method": {
            "description": "Human-readable heuristic used for token estimates.",
            "minLength": 1,
            "title": "Token Estimate Method",
            "type": "string"
          }
        },
        "required": [
          "candidate_count",
          "estimated_prompt_tokens",
          "estimated_completion_tokens",
          "estimated_total_tokens",
          "cost_estimate_available",
          "classification_mode",
          "llm_provider",
          "model",
          "prompt_version",
          "token_estimate_method"
        ],
        "title": "ClassificationPreRunEstimate",
        "type": "object"
      },
      "EmailAccountRef": {
        "description": "Provider-neutral stable reference to a connected mailbox account.",
        "properties": {
          "account_id": {
            "minLength": 1,
            "title": "Account Id",
            "type": "string"
          },
          "provider": {
            "$ref": "#/components/schemas/EmailProviderName"
          }
        },
        "required": [
          "provider",
          "account_id"
        ],
        "title": "EmailAccountRef",
        "type": "object"
      },
      "EmailAddress": {
        "description": "Provider-normalized email address plus optional display name.\n\nProvider adapters should lower-case parsed addresses, trim display names,\nand deduplicate repeated recipients before returning metadata DTOs.",
        "properties": {
          "address": {
            "minLength": 1,
            "title": "Address",
            "type": "string"
          },
          "display_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Display Name"
          }
        },
        "required": [
          "address"
        ],
        "title": "EmailAddress",
        "type": "object"
      },
      "EmailAuthorizationStartResult": {
        "description": "Provider-neutral authorization URL and scope request.",
        "properties": {
          "authorization_url": {
            "minLength": 1,
            "title": "Authorization Url",
            "type": "string"
          },
          "provider": {
            "$ref": "#/components/schemas/EmailProviderName"
          },
          "requested_scopes": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "title": "Requested Scopes",
            "type": "array"
          },
          "state": {
            "minLength": 1,
            "title": "State",
            "type": "string"
          }
        },
        "required": [
          "provider",
          "authorization_url",
          "state",
          "requested_scopes"
        ],
        "title": "EmailAuthorizationStartResult",
        "type": "object"
      },
      "EmailConnection": {
        "description": "Stored account connection metadata without raw OAuth token material.",
        "properties": {
          "account": {
            "$ref": "#/components/schemas/EmailAccountRef"
          },
          "connected_at": {
            "format": "date-time",
            "title": "Connected At",
            "type": "string"
          },
          "credential_expires_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Credential Expires At"
          },
          "credential_ref": {
            "$ref": "#/components/schemas/SecretRef"
          },
          "display_email": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/EmailAddress"
              },
              {
                "type": "null"
              }
            ]
          },
          "granted_scopes": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "title": "Granted Scopes",
            "type": "array"
          },
          "reauth_required": {
            "default": false,
            "title": "Reauth Required",
            "type": "boolean"
          }
        },
        "required": [
          "account",
          "credential_ref",
          "granted_scopes",
          "connected_at"
        ],
        "title": "EmailConnection",
        "type": "object"
      },
      "EmailProviderConfigResponse": {
        "description": "Email provider metadata exposed by the provider config API shell.",
        "properties": {
          "config_requirements": {
            "items": {
              "$ref": "#/components/schemas/ProviderConfigRequirementResponse"
            },
            "title": "Config Requirements",
            "type": "array"
          },
          "display_name": {
            "title": "Display Name",
            "type": "string"
          },
          "name": {
            "$ref": "#/components/schemas/EmailProviderName"
          },
          "secret_requirements": {
            "items": {
              "$ref": "#/components/schemas/ProviderSecretRequirementResponse"
            },
            "title": "Secret Requirements",
            "type": "array"
          }
        },
        "required": [
          "name",
          "display_name",
          "config_requirements",
          "secret_requirements"
        ],
        "title": "EmailProviderConfigResponse",
        "type": "object"
      },
      "EmailProviderName": {
        "enum": [
          "gmail"
        ],
        "title": "EmailProviderName",
        "type": "string"
      },
      "EmailSyncMode": {
        "enum": [
          "full_backfill",
          "incremental"
        ],
        "title": "EmailSyncMode",
        "type": "string"
      },
      "EmailSyncRunState": {
        "enum": [
          "idle",
          "running",
          "succeeded",
          "failed"
        ],
        "title": "EmailSyncRunState",
        "type": "string"
      },
      "EmailSyncStatus": {
        "description": "Current or last manual sync run status exposed at the API boundary.",
        "properties": {
          "account_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Account Id"
          },
          "finished_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Finished At"
          },
          "last_error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Error"
          },
          "message_count": {
            "default": 0,
            "minimum": 0.0,
            "title": "Message Count",
            "type": "integer"
          },
          "mode": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/EmailSyncMode"
              },
              {
                "type": "null"
              }
            ]
          },
          "page_count": {
            "default": 0,
            "minimum": 0.0,
            "title": "Page Count",
            "type": "integer"
          },
          "provider": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/EmailProviderName"
              },
              {
                "type": "null"
              }
            ]
          },
          "raw_email_count": {
            "default": 0,
            "minimum": 0.0,
            "title": "Raw Email Count",
            "type": "integer"
          },
          "recovered_from_expired_cursor": {
            "default": false,
            "title": "Recovered From Expired Cursor",
            "type": "boolean"
          },
          "started_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "state": {
            "$ref": "#/components/schemas/EmailSyncRunState"
          }
        },
        "required": [
          "state"
        ],
        "title": "EmailSyncStatus",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "const": "ok",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "LLMModelHealthCheck": {
        "description": "Availability result for one configured provider model.",
        "properties": {
          "detail": {
            "anyOf": [
              {
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Detail"
          },
          "kind": {
            "$ref": "#/components/schemas/LLMModelKind"
          },
          "model": {
            "minLength": 1,
            "title": "Model",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/LLMModelHealthStatus"
          }
        },
        "required": [
          "kind",
          "model",
          "status"
        ],
        "title": "LLMModelHealthCheck",
        "type": "object"
      },
      "LLMModelHealthStatus": {
        "enum": [
          "available",
          "unavailable"
        ],
        "title": "LLMModelHealthStatus",
        "type": "string"
      },
      "LLMModelKind": {
        "enum": [
          "chat",
          "embedding"
        ],
        "title": "LLMModelKind",
        "type": "string"
      },
      "LLMProviderConfigResponse": {
        "description": "LLM provider metadata exposed by the provider config API shell.",
        "properties": {
          "config_requirements": {
            "items": {
              "$ref": "#/components/schemas/ProviderConfigRequirementResponse"
            },
            "title": "Config Requirements",
            "type": "array"
          },
          "display_name": {
            "title": "Display Name",
            "type": "string"
          },
          "is_local": {
            "title": "Is Local",
            "type": "boolean"
          },
          "name": {
            "$ref": "#/components/schemas/LLMProviderName"
          },
          "secret_requirements": {
            "items": {
              "$ref": "#/components/schemas/ProviderSecretRequirementResponse"
            },
            "title": "Secret Requirements",
            "type": "array"
          }
        },
        "required": [
          "name",
          "display_name",
          "is_local",
          "config_requirements",
          "secret_requirements"
        ],
        "title": "LLMProviderConfigResponse",
        "type": "object"
      },
      "LLMProviderHealthCheckResponse": {
        "description": "Provider-neutral health-check result for the selected LLM provider.",
        "properties": {
          "checks": {
            "items": {
              "$ref": "#/components/schemas/LLMModelHealthCheck"
            },
            "minItems": 1,
            "title": "Checks",
            "type": "array"
          },
          "provider_name": {
            "minLength": 1,
            "title": "Provider Name",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/LLMModelHealthStatus"
          }
        },
        "required": [
          "provider_name",
          "status",
          "checks"
        ],
        "title": "LLMProviderHealthCheckResponse",
        "type": "object"
      },
      "LLMProviderName": {
        "enum": [
          "azure_openai",
          "ollama"
        ],
        "title": "LLMProviderName",
        "type": "string"
      },
      "ProviderConfigRequirementResponse": {
        "description": "Non-secret provider setting required by a supported provider.",
        "properties": {
          "enforcement": {
            "$ref": "#/components/schemas/ProviderRequirementEnforcement"
          },
          "label": {
            "title": "Label",
            "type": "string"
          },
          "required": {
            "title": "Required",
            "type": "boolean"
          },
          "setting_name": {
            "title": "Setting Name",
            "type": "string"
          }
        },
        "required": [
          "setting_name",
          "label",
          "required",
          "enforcement"
        ],
        "title": "ProviderConfigRequirementResponse",
        "type": "object"
      },
      "ProviderConfigResponse": {
        "description": "Selected provider config plus supported provider metadata.",
