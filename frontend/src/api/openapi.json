            "schema": {
              "format": "password",
              "minLength": 1,
              "title": "Code",
              "type": "string",
              "writeOnly": true
            }
          },
          {
            "in": "query",
            "name": "state",
            "required": true,
            "schema": {
              "minLength": 1,
              "title": "State",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmailConnection"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "content": {
