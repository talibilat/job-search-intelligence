        "description": "Currently selected provider choices for the setup/config shell.",
        "properties": {
          "classification_mode": {
            "$ref": "#/components/schemas/ClassificationMode"
          },
          "email_provider": {
            "$ref": "#/components/schemas/EmailProviderName"
          },
          "llm_provider": {
            "$ref": "#/components/schemas/LLMProviderName"
          }
        },
        "required": [
          "email_provider",
