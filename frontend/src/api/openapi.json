        "enum": [
          "oauth_token",
          "llm_api_key"
        ],
        "title": "SecretKind",
        "type": "string"
      },
      "SecretRef": {
        "description": "Stable non-secret identifier for a stored secret.",
        "properties": {
          "kind": {
            "$ref": "#/components/schemas/SecretKind"
          },
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "pattern": "^[a-z0-9][a-z0-9_.:-]*$",
            "title": "Name",
            "type": "string"
          },
          "provider": {
            "maxLength": 100,
            "minLength": 1,
            "pattern": "^[a-z0-9][a-z0-9_.:-]*$",
            "title": "Provider",
            "type": "string"
          }
        },
        "required": [
          "kind",
          "provider",
          "name"
        ],
